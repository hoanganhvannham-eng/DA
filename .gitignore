# Root .gitignore for entire project

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
desktop.ini

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# Build artifacts
dist/
build/
out/

# Temporary files
*.tmp
*.temp
.cache/

# Include backend and frontend specific gitignores
!backend/.gitignore
!frontend/.gitignore
